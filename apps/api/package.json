{
  "name": "@aegis/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "entries:migrate-legacy": "tsx src/scripts/migrate-legacy-entries.ts",
    "notifications:scan": "tsx src/scripts/enqueue-notification-scan.ts",
    "notifications:scan:now": "tsx src/scripts/run-notification-scan.ts",
    "notifications:worker": "tsx src/workers/notifications.ts",
    "projects:repair-depths": "tsx src/scripts/repair-project-depths.ts",
    "search:rebuild": "tsx src/scripts/rebuild-search-index.ts",
    "start": "node dist/index.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "echo format not configured",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@aws-sdk/s3-request-presigner": "^3.1009.0",
    "@clerk/backend": "^3.2.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@aegis/presets": "workspace:*",
    "@aegis/types": "workspace:*",
    "@aegis/utils": "workspace:*",
    "@prisma/client": "^6.4.1",
    "bullmq": "^5.70.4",
    "bwip-js": "^4.8.0",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.10.0",
    "nanoid": "^5.1.7",
    "nodemailer": "^8.0.3",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "sanitize-html": "^2.17.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^7.0.11",
    "@types/pdfkit": "^0.17.5",
    "@types/qrcode": "^1.5.6",
    "@types/sanitize-html": "^2.16.1",
    "prisma": "^6.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
