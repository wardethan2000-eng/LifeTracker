generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum HouseholdRole {
  owner
  member
}

enum AssetCategory {
  vehicle
  home
  marine
  yard
  workshop
  appliance
  hvac
  technology
  other
}

enum AssetVisibility {
  shared
  personal
}

enum TriggerType {
  interval
  usage
  seasonal
  compound
  one_time
}

enum NotificationType {
  due_soon
  due
  overdue
  digest
  announcement
}

enum NotificationChannel {
  push
  email
  digest
}

enum NotificationStatus {
  pending
  sent
  failed
  read
}

model User {
  id                  String             @id @default(cuid())
  clerkUserId         String             @unique
  email               String?            @unique
  displayName         String?
  notificationPreferences Json           @default("{}")
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  householdMemberships HouseholdMember[]
  householdsCreated   Household[]        @relation("HouseholdCreator")
  createdAssets       Asset[]            @relation("AssetCreator")
  createdPresetProfiles PresetProfile[]  @relation("PresetProfileCreator")
  maintenanceLogs     MaintenanceLog[]   @relation("MaintenanceLogUser")
  notifications       Notification[]
}

model Household {
  id            String             @id @default(cuid())
  name          String
  createdById   String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  createdBy     User               @relation("HouseholdCreator", fields: [createdById], references: [id], onDelete: Restrict)
  members       HouseholdMember[]
  assets        Asset[]
  presetProfiles PresetProfile[]
  notifications Notification[]
  serviceProviders ServiceProvider[]

  @@index([createdById])
}

model HouseholdMember {
  id          String        @id @default(cuid())
  householdId String
  userId      String
  role        HouseholdRole @default(member)
  joinedAt    DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
  @@index([userId])
}

model Asset {
  id             String                @id @default(cuid())
  householdId    String
  createdById    String
  parentAssetId  String?
  name           String
  category       AssetCategory
  visibility     AssetVisibility       @default(shared)
  description    String?
  manufacturer   String?
  model          String?
  serialNumber   String?
  purchaseDate   DateTime?
  purchaseDetails    Json?
  warrantyDetails    Json?
  locationDetails    Json?
  insuranceDetails   Json?
  dispositionDetails Json?
  conditionScore     Int?
  conditionHistory   Json              @default("[]")
  assetTypeKey   String?
  assetTypeLabel String?
  assetTypeDescription String?
  assetTypeSource String                @default("manual")
  assetTypeVersion Int                  @default(1)
  fieldDefinitions Json                 @default("[]")
  customFields   Json                  @default("{}")
  isArchived     Boolean               @default(false)
  deletedAt      DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  household      Household             @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy      User                  @relation("AssetCreator", fields: [createdById], references: [id], onDelete: Restrict)
  parentAsset    Asset?                @relation("AssetHierarchy", fields: [parentAssetId], references: [id], onDelete: SetNull)
  childAssets    Asset[]               @relation("AssetHierarchy")
  usageMetrics   UsageMetric[]
  schedules      MaintenanceSchedule[]
  logs           MaintenanceLog[]
  notifications  Notification[]

  @@index([householdId, isArchived])
  @@index([createdById])
  @@index([category])
  @@index([parentAssetId])
}

model UsageMetric {
  id             String                @id @default(cuid())
  assetId        String
  name           String
  unit           String
  currentValue   Float                 @default(0)
  lastRecordedAt DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  asset          Asset                 @relation(fields: [assetId], references: [id], onDelete: Cascade)
  entries        UsageMetricEntry[]
  schedules      MaintenanceSchedule[]

  @@index([assetId])
}

model UsageMetricEntry {
  id         String      @id @default(cuid())
  metricId   String
  value      Float
  recordedAt DateTime    @default(now())
  source     String      @default("manual")
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  metric     UsageMetric @relation(fields: [metricId], references: [id], onDelete: Cascade)

  @@index([metricId, recordedAt])
}

model MaintenanceSchedule {
  id             String          @id @default(cuid())
  assetId        String
  metricId       String?
  name           String
  description    String?
  triggerType    TriggerType
  triggerConfig  Json
  notificationConfig Json        @default("{}")
  presetKey      String?
  isActive       Boolean         @default(true)
  lastCompletedAt DateTime?
  nextDueAt      DateTime?
  nextDueMetricValue Float?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  asset          Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  metric         UsageMetric?    @relation(fields: [metricId], references: [id], onDelete: SetNull)
  logs           MaintenanceLog[]
  notifications  Notification[]

  @@index([assetId, isActive])
  @@index([metricId])
  @@index([nextDueAt])
}

model PresetProfile {
  id                  String    @id @default(cuid())
  householdId         String
  createdById         String
  key                 String
  name                String
  category            AssetCategory
  description         String?
  tags                String[]  @default([])
  customFieldTemplates Json     @default("[]")
  metricTemplates     Json      @default("[]")
  scheduleTemplates   Json      @default("[]")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  household           Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy           User      @relation("PresetProfileCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([householdId])
  @@index([createdById])
  @@unique([householdId, key])
}

model ServiceProvider {
  id            String           @id @default(cuid())
  householdId   String
  name          String
  specialty     String?
  phone         String?
  email         String?
  website       String?
  address       String?
  rating        Int?
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  household     Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  maintenanceLogs MaintenanceLog[]

  @@index([householdId])
}

model MaintenanceLog {
  id                String               @id @default(cuid())
  assetId           String
  scheduleId        String?
  completedById     String
  serviceProviderId String?
  title             String
  notes             String?
  completedAt       DateTime
  usageValue        Float?
  cost              Float?
  metadata          Json                 @default("{}")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  asset             Asset                @relation(fields: [assetId], references: [id], onDelete: Cascade)
  schedule          MaintenanceSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  completedBy       User                 @relation("MaintenanceLogUser", fields: [completedById], references: [id], onDelete: Restrict)
  serviceProvider   ServiceProvider?     @relation(fields: [serviceProviderId], references: [id], onDelete: SetNull)
  parts             MaintenanceLogPart[]

  @@index([assetId, completedAt])
  @@index([scheduleId])
  @@index([completedById])
  @@index([serviceProviderId])
}

model MaintenanceLogPart {
  id         String         @id @default(cuid())
  logId      String
  name       String
  partNumber String?
  quantity   Float          @default(1)
  unitCost   Float?
  supplier   String?
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  log        MaintenanceLog @relation(fields: [logId], references: [id], onDelete: Cascade)

  @@index([logId])
}

model Notification {
  id              String             @id @default(cuid())
  userId          String
  householdId     String?
  assetId         String?
  scheduleId      String?
  dedupeKey       String             @unique
  type            NotificationType
  channel         NotificationChannel
  status          NotificationStatus @default(pending)
  title           String
  body            String
  scheduledFor    DateTime
  sentAt          DateTime?
  readAt          DateTime?
  escalationLevel Int                @default(0)
  payload         Json               @default("{}")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  household       Household?         @relation(fields: [householdId], references: [id], onDelete: Cascade)
  asset           Asset?             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  schedule        MaintenanceSchedule? @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([scheduledFor])
  @@index([householdId])
  @@index([assetId])
  @@index([scheduleId])
}
