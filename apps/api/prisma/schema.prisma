generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum HouseholdRole {
  owner
  member
}

enum AssetCategory {
  vehicle
  home
  marine
  aircraft
  yard
  workshop
  appliance
  hvac
  technology
  other
}

enum AssetVisibility {
  shared
  personal
}

enum AssetTransferType {
  reassignment
  household_transfer
}

enum TriggerType {
  interval
  usage
  seasonal
  compound
  one_time
}

enum NotificationType {
  due_soon
  due
  overdue
  digest
  announcement
}

enum NotificationChannel {
  push
  email
  digest
}

enum NotificationStatus {
  pending
  sent
  failed
  read
}

enum ProjectStatus {
  planning
  active
  on_hold
  completed
  cancelled
}

enum NoteCategory {
  research
  reference
  decision
  measurement
  general
}

enum InvitationStatus {
  pending
  accepted
  expired
  revoked
}

enum ProjectAssetRelationship {
  target
  produces
  consumes
  supports
}

model User {
  id                      String                @id @default(cuid())
  clerkUserId             String                @unique
  email                   String?               @unique
  displayName             String?
  notificationPreferences Json                  @default("{}")
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  householdMemberships    HouseholdMember[]
  householdsCreated       Household[]           @relation("HouseholdCreator")
  createdAssets           Asset[]               @relation("AssetCreator")
  ownedAssets             Asset[]               @relation("AssetOwner")
  createdPresetProfiles   PresetProfile[]       @relation("PresetProfileCreator")
  maintenanceLogs         MaintenanceLog[]      @relation("MaintenanceLogUser")
  notifications           Notification[]
  assignedSchedules       MaintenanceSchedule[] @relation("ScheduleAssignee")
  assignedProjectTasks    ProjectTask[]         @relation("ProjectTaskAssignee")
  activityLogs            ActivityLog[]
  initiatedAssetTransfers AssetTransfer[]       @relation("AssetTransferInitiator")
  outgoingAssetTransfers  AssetTransfer[]       @relation("AssetTransferFromUser")
  incomingAssetTransfers  AssetTransfer[]       @relation("AssetTransferToUser")
  inventoryTransactions   InventoryTransaction[]
  sentInvitations         HouseholdInvitation[] @relation("InvitationSender")
  acceptedInvitations     HouseholdInvitation[] @relation("InvitationAcceptor")
  authoredComments        Comment[]             @relation("CommentAuthor")
  projectNotes            ProjectNote[]         @relation("ProjectNoteAuthor")
}

model Household {
  id               String                @id @default(cuid())
  name             String
  createdById      String
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  createdBy        User                  @relation("HouseholdCreator", fields: [createdById], references: [id], onDelete: Restrict)
  members          HouseholdMember[]
  assets           Asset[]
  presetProfiles   PresetProfile[]
  notifications    Notification[]
  serviceProviders ServiceProvider[]
  projects         Project[]
  inventoryItems   InventoryItem[]
  activityLogs     ActivityLog[]
  outgoingAssetTransfers AssetTransfer[]        @relation("AssetTransferFromHousehold")
  incomingAssetTransfers AssetTransfer[]        @relation("AssetTransferToHousehold")
  invitations      HouseholdInvitation[]

  @@index([createdById])
}

model HouseholdMember {
  id          String        @id @default(cuid())
  householdId String
  userId      String
  role        HouseholdRole @default(member)
  joinedAt    DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
  @@index([userId])
}

model Asset {
  id                   String                @id @default(cuid())
  householdId          String
  createdById          String
  ownerId              String?
  parentAssetId        String?
  assetTag             String?               @unique
  name                 String
  category             AssetCategory
  visibility           AssetVisibility       @default(shared)
  description          String?
  manufacturer         String?
  model                String?
  serialNumber         String?
  purchaseDate         DateTime?
  purchaseDetails      Json?
  warrantyDetails      Json?
  locationDetails      Json?
  insuranceDetails     Json?
  dispositionDetails   Json?
  conditionScore       Int?
  conditionHistory     Json                  @default("[]")
  assetTypeKey         String?
  assetTypeLabel       String?
  assetTypeDescription String?
  assetTypeSource      String                @default("manual")
  assetTypeVersion     Int                   @default(1)
  fieldDefinitions     Json                  @default("[]")
  customFields         Json                  @default("{}")
  isArchived           Boolean               @default(false)
  deletedAt            DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  household            Household             @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy            User                  @relation("AssetCreator", fields: [createdById], references: [id], onDelete: Restrict)
  owner                User?                 @relation("AssetOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  parentAsset          Asset?                @relation("AssetHierarchy", fields: [parentAssetId], references: [id], onDelete: SetNull)
  childAssets          Asset[]               @relation("AssetHierarchy")
  usageMetrics         UsageMetric[]
  schedules            MaintenanceSchedule[]
  logs                 MaintenanceLog[]
  inventoryLinks       AssetInventoryItem[]
  notifications        Notification[]
  projectAssets        ProjectAsset[]
  comments             Comment[]
  transfers            AssetTransfer[]

  @@index([householdId, isArchived])
  @@index([createdById])
  @@index([ownerId])
  @@index([category])
  @@index([parentAssetId])
}

model AssetTransfer {
  id              String            @id @default(cuid())
  assetId         String
  transferType    AssetTransferType
  fromHouseholdId String
  toHouseholdId   String?
  fromUserId      String
  toUserId        String
  initiatedById   String
  reason          String?
  notes           String?
  transferredAt   DateTime          @default(now())
  createdAt       DateTime          @default(now())
  asset           Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  fromHousehold   Household         @relation("AssetTransferFromHousehold", fields: [fromHouseholdId], references: [id], onDelete: Cascade)
  toHousehold     Household?        @relation("AssetTransferToHousehold", fields: [toHouseholdId], references: [id], onDelete: SetNull)
  fromUser        User              @relation("AssetTransferFromUser", fields: [fromUserId], references: [id], onDelete: Restrict)
  toUser          User              @relation("AssetTransferToUser", fields: [toUserId], references: [id], onDelete: Restrict)
  initiatedBy     User              @relation("AssetTransferInitiator", fields: [initiatedById], references: [id], onDelete: Restrict)

  @@index([assetId, transferredAt])
  @@index([fromHouseholdId, transferredAt])
  @@index([toHouseholdId, transferredAt])
}

model UsageMetric {
  id             String                @id @default(cuid())
  assetId        String
  name           String
  unit           String
  currentValue   Float                 @default(0)
  lastRecordedAt DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  asset          Asset                 @relation(fields: [assetId], references: [id], onDelete: Cascade)
  entries        UsageMetricEntry[]
  schedules      MaintenanceSchedule[]

  @@index([assetId])
}

model UsageMetricEntry {
  id         String      @id @default(cuid())
  metricId   String
  value      Float
  recordedAt DateTime    @default(now())
  source     String      @default("manual")
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  metric     UsageMetric @relation(fields: [metricId], references: [id], onDelete: Cascade)

  @@index([metricId, recordedAt])
}

model MaintenanceSchedule {
  id                 String           @id @default(cuid())
  assetId            String
  metricId           String?
  name               String
  description        String?
  triggerType        TriggerType
  triggerConfig      Json
  notificationConfig Json             @default("{}")
  presetKey          String?
  isActive           Boolean          @default(true)
  lastCompletedAt    DateTime?
  nextDueAt          DateTime?
  nextDueMetricValue Float?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  asset              Asset            @relation(fields: [assetId], references: [id], onDelete: Cascade)
  metric             UsageMetric?     @relation(fields: [metricId], references: [id], onDelete: SetNull)
  assignedToId       String?
  logs               MaintenanceLog[]
  notifications      Notification[]
  linkedProjectTasks ProjectTask[]    @relation("ProjectTaskSchedule")
  assignedTo         User?            @relation("ScheduleAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([assetId, isActive])
  @@index([metricId])
  @@index([nextDueAt])
  @@index([assignedToId])
}

model PresetProfile {
  id                   String        @id @default(cuid())
  householdId          String
  createdById          String
  key                  String
  name                 String
  category             AssetCategory
  description          String?
  tags                 String[]      @default([])
  customFieldTemplates Json          @default("[]")
  metricTemplates      Json          @default("[]")
  scheduleTemplates    Json          @default("[]")
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  household            Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy            User          @relation("PresetProfileCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@unique([householdId, key])
  @@index([householdId])
  @@index([createdById])
}

model ServiceProvider {
  id              String           @id @default(cuid())
  householdId     String
  name            String
  specialty       String?
  phone           String?
  email           String?
  website         String?
  address         String?
  rating          Int?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  household       Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  maintenanceLogs MaintenanceLog[]
  projectExpenses ProjectExpense[]

  @@index([householdId])
}

model MaintenanceLog {
  id                String               @id @default(cuid())
  assetId           String
  scheduleId        String?
  completedById     String
  serviceProviderId String?
  title             String
  notes             String?
  completedAt       DateTime
  usageValue        Float?
  cost              Float?
  laborHours        Float?
  laborRate         Float?
  difficultyRating  Int?
  performedBy       String?
  metadata          Json                 @default("{}")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  asset             Asset                @relation(fields: [assetId], references: [id], onDelete: Cascade)
  schedule          MaintenanceSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  completedBy       User                 @relation("MaintenanceLogUser", fields: [completedById], references: [id], onDelete: Restrict)
  serviceProvider   ServiceProvider?     @relation(fields: [serviceProviderId], references: [id], onDelete: SetNull)
  parts             MaintenanceLogPart[]

  @@index([assetId, completedAt])
  @@index([scheduleId])
  @@index([completedById])
  @@index([serviceProviderId])
}

model MaintenanceLogPart {
  id         String         @id @default(cuid())
  logId      String
  inventoryItemId String?
  name       String
  partNumber String?
  quantity   Float          @default(1)
  unitCost   Float?
  supplier   String?
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  log        MaintenanceLog @relation(fields: [logId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)

  @@index([logId])
  @@index([inventoryItemId])
}

model Notification {
  id              String               @id @default(cuid())
  userId          String
  householdId     String?
  assetId         String?
  scheduleId      String?
  dedupeKey       String               @unique
  type            NotificationType
  channel         NotificationChannel
  status          NotificationStatus   @default(pending)
  title           String
  body            String
  scheduledFor    DateTime
  sentAt          DateTime?
  readAt          DateTime?
  escalationLevel Int                  @default(0)
  payload         Json                 @default("{}")
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  household       Household?           @relation(fields: [householdId], references: [id], onDelete: Cascade)
  asset           Asset?               @relation(fields: [assetId], references: [id], onDelete: Cascade)
  schedule        MaintenanceSchedule? @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([scheduledFor])
  @@index([householdId])
  @@index([assetId])
  @@index([scheduleId])
}

// ── Projects Domain ──────────────────────────────────────────────────

model Project {
  id            String           @id @default(cuid())
  householdId   String
  name          String
  description   String?
  status        ProjectStatus    @default(planning)
  startDate     DateTime?
  targetEndDate DateTime?
  actualEndDate DateTime?
  budgetAmount    Float?
  notes           String?
  parentProjectId String?
  depth           Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  household       Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  parentProject   Project?         @relation("ProjectHierarchy", fields: [parentProjectId], references: [id], onDelete: Cascade)
  childProjects   Project[]        @relation("ProjectHierarchy")
  assets          ProjectAsset[]
  inventoryItems  ProjectInventoryItem[]
  phases          ProjectPhase[]
  budgetCategories ProjectBudgetCategory[]
  tasks           ProjectTask[]
  expenses        ProjectExpense[]
  noteEntries     ProjectNote[]

  @@index([householdId, status])
  @@index([parentProjectId])
}

model InventoryItem {
  id                 String                  @id @default(cuid())
  householdId        String
  name               String
  partNumber         String?
  description        String?
  category           String?
  manufacturer       String?
  quantityOnHand     Float                   @default(0)
  unit               String                  @default("each")
  reorderThreshold   Float?
  reorderQuantity    Float?
  preferredSupplier  String?
  supplierUrl        String?
  unitCost           Float?
  storageLocation    String?
  notes              String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  household          Household               @relation(fields: [householdId], references: [id], onDelete: Cascade)
  assetLinks         AssetInventoryItem[]
  projectLinks       ProjectInventoryItem[]
  projectPhaseSupplies ProjectPhaseSupply[]
  transactions       InventoryTransaction[]
  maintenanceLogParts MaintenanceLogPart[]

  @@index([householdId])
  @@index([householdId, category])
  @@index([householdId, partNumber])
}

model AssetInventoryItem {
  id                String        @id @default(cuid())
  assetId           String
  inventoryItemId   String
  notes             String?
  recommendedQuantity Float?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  asset             Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  inventoryItem     InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([assetId, inventoryItemId])
  @@index([assetId])
  @@index([inventoryItemId])
}

model ProjectInventoryItem {
  id                String        @id @default(cuid())
  projectId         String
  inventoryItemId   String
  quantityNeeded    Float
  quantityAllocated Float         @default(0)
  budgetedUnitCost  Float?
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  project           Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inventoryItem     InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([projectId, inventoryItemId])
  @@index([projectId])
  @@index([inventoryItemId])
}

model InventoryTransaction {
  id              String        @id @default(cuid())
  inventoryItemId String
  type            String
  quantity        Float
  quantityAfter   Float
  referenceType   String?
  referenceId     String?
  unitCost        Float?
  notes           String?
  userId          String
  createdAt       DateTime      @default(now())
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([inventoryItemId, createdAt])
  @@index([referenceType, referenceId])
  @@index([userId])
}

model ProjectAsset {
  id           String                   @id @default(cuid())
  projectId    String
  assetId      String
  relationship ProjectAssetRelationship @default(target)
  role         String?
  notes        String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  project      Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asset        Asset                    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([projectId, assetId])
  @@index([projectId])
  @@index([assetId])
}

model ProjectTask {
  id            String               @id @default(cuid())
  projectId     String
  phaseId       String?
  title         String
  description   String?
  status        String               @default("pending")
  taskType      String               @default("full")
  isCompleted   Boolean              @default(false)
  assignedToId  String?
  dueDate       DateTime?
  completedAt   DateTime?
  estimatedCost Float?
  actualCost    Float?
  sortOrder     Int?
  scheduleId    String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  project       Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase         ProjectPhase?        @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  assignedTo    User?                @relation("ProjectTaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  schedule      MaintenanceSchedule? @relation("ProjectTaskSchedule", fields: [scheduleId], references: [id], onDelete: SetNull)
  checklistItems ProjectTaskChecklistItem[]

  @@index([projectId, status])
  @@index([projectId, taskType])
  @@index([phaseId, sortOrder])
  @@index([assignedToId])
}

model ProjectNote {
  id             String        @id @default(cuid())
  projectId      String
  phaseId        String?
  title          String
  body           String        @default("")
  url            String?
  category       NoteCategory  @default(general)
  attachmentUrl  String?
  attachmentName String?
  isPinned       Boolean       @default(false)
  createdById    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase          ProjectPhase? @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  createdBy      User          @relation("ProjectNoteAuthor", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([projectId, category])
  @@index([projectId, isPinned])
  @@index([phaseId])
  @@index([createdById])
}

model ProjectExpense {
  id                String           @id @default(cuid())
  projectId         String
  phaseId           String?
  budgetCategoryId  String?
  description       String
  amount            Float
  category          String?
  date              DateTime?
  taskId            String?
  serviceProviderId String?
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  project           Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase             ProjectPhase?    @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  budgetCategory    ProjectBudgetCategory? @relation(fields: [budgetCategoryId], references: [id], onDelete: SetNull)
  serviceProvider   ServiceProvider? @relation(fields: [serviceProviderId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([phaseId])
  @@index([budgetCategoryId])
}

model ProjectPhase {
  id             String                      @id @default(cuid())
  projectId      String
  name           String
  description    String?
  status         String                      @default("pending")
  sortOrder      Int?
  startDate      DateTime?
  targetEndDate  DateTime?
  actualEndDate  DateTime?
  budgetAmount   Float?
  notes          String?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  project        Project                     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks          ProjectTask[]
  checklistItems ProjectPhaseChecklistItem[]
  expenses       ProjectExpense[]
  supplies       ProjectPhaseSupply[]
  noteEntries    ProjectNote[]

  @@index([projectId, sortOrder])
  @@index([projectId, status])
}

model ProjectPhaseChecklistItem {
  id           String       @id @default(cuid())
  phaseId      String
  title        String
  isCompleted  Boolean      @default(false)
  completedAt  DateTime?
  sortOrder    Int?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  phase        ProjectPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  @@index([phaseId, sortOrder])
}

model ProjectTaskChecklistItem {
  id           String      @id @default(cuid())
  taskId       String
  title        String
  isCompleted  Boolean     @default(false)
  completedAt  DateTime?
  sortOrder    Int?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  task         ProjectTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, sortOrder])
}

model ProjectBudgetCategory {
  id           String           @id @default(cuid())
  projectId    String
  name         String
  budgetAmount Float?
  sortOrder    Int?
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  expenses     ProjectExpense[]

  @@index([projectId, sortOrder])
}

model ProjectPhaseSupply {
  id                String         @id @default(cuid())
  phaseId           String
  name              String
  description       String?
  quantityNeeded    Float
  quantityOnHand    Float          @default(0)
  unit              String         @default("each")
  estimatedUnitCost Float?
  actualUnitCost    Float?
  supplier          String?
  supplierUrl       String?
  isProcured        Boolean        @default(false)
  procuredAt        DateTime?
  isStaged          Boolean        @default(false)
  stagedAt          DateTime?
  inventoryItemId   String?
  notes             String?
  sortOrder         Int?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  phase             ProjectPhase   @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  inventoryItem     InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)

  @@index([phaseId, sortOrder])
  @@index([phaseId, isProcured])
  @@index([inventoryItemId])
}

model SearchIndex {
  id               String                 @id
  householdId      String
  entityType       String
  entityId         String
  parentEntityId   String?
  parentEntityName String?
  title            String
  subtitle         String?
  body             String?
  searchVector     Unsupported("tsvector")
  entityUrl        String
  entityMeta       Json?
  updatedAt        DateTime               @updatedAt

  @@unique([entityType, entityId])
  @@index([householdId, entityType])
}

// ── Activity Log ─────────────────────────────────────────────────────

model ActivityLog {
  id          String    @id @default(cuid())
  householdId String
  userId      String
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  createdAt   DateTime  @default(now())
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([householdId, createdAt])
  @@index([userId])
  @@index([entityType, entityId])
}

// ── Household Invitations ────────────────────────────────────────────

model HouseholdInvitation {
  id               String           @id @default(cuid())
  householdId      String
  invitedByUserId  String
  email            String
  status           InvitationStatus @default(pending)
  token            String           @unique
  expiresAt        DateTime
  acceptedAt       DateTime?
  acceptedByUserId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  household        Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  invitedBy        User             @relation("InvitationSender", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  acceptedBy       User?            @relation("InvitationAcceptor", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([householdId])
  @@index([email])
}

// ── Comments ─────────────────────────────────────────────────────────

model Comment {
  id              String    @id @default(cuid())
  assetId         String
  authorId        String
  body            String
  parentCommentId String?
  editedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  asset           Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  author          User      @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parentComment   Comment?  @relation("CommentThread", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies         Comment[] @relation("CommentThread")

  @@index([assetId, createdAt])
  @@index([authorId])
  @@index([parentCommentId])
}

// ── Barcode Lookup Cache ─────────────────────────────────────────────

model BarcodeLookup {
  id             String   @id @default(cuid())
  barcode        String   @unique
  barcodeFormat  String
  productName    String?
  brand          String?
  description    String?
  category       String?
  imageUrl       String?
  sourceProvider String
  rawResponse    Json     @default("{}")
