// ╔══════════════════════════════════════════════════════════════════╗
// ║  PRISMA CONFIGURATION                                           ║
// ╚══════════════════════════════════════════════════════════════════╝

// Generates the Prisma Client consumed by the API and other TypeScript apps.
generator client {
  provider = "prisma-client-js"
}

// Connects Prisma to the PostgreSQL database configured by DATABASE_URL.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  ENUMS                                                          ║
// ╚══════════════════════════════════════════════════════════════════╝

// Household membership role used for access control and ownership rules.
enum HouseholdRole {
  owner
  member
}

// Broad asset taxonomy used for filtering, presets, and specialized UX.
enum AssetCategory {
  vehicle
  home
  marine
  aircraft
  yard
  workshop
  appliance
  hvac
  technology
  other
}

// Controls whether an asset is shared with the household or only its owner.
enum AssetVisibility {
  shared
  personal
}

// Distinguishes direct reassignment from movement between households.
enum AssetTransferType {
  reassignment      // Moves the asset between users in the same household
  household_transfer // Moves the asset into another household context
}

// Defines how a maintenance schedule becomes due.
enum TriggerType {
  interval // Time-based recurrence after a fixed interval
  usage    // Due after a tracked metric advances by N units
  seasonal // Due during specific calendar windows or months
  compound // Combines multiple due rules into one schedule
  one_time // Single due event with no recurring trigger
}

// Classifies notification intent for maintenance and household messaging.
enum NotificationType {
  due_soon
  due
  overdue
  digest
  announcement
  inventory_low_stock
}

// Delivery channel selected for a notification.
enum NotificationChannel {
  push
  email
  digest // Holds items for batched summary delivery
}

// Tracks delivery lifecycle after a notification is generated.
enum NotificationStatus {
  pending
  sent
  failed
  read
}

// Workflow state for household inventory purchase batches.
enum InventoryPurchaseStatus {
  draft
  ordered
  received
}

// Indicates whether a purchase batch came from reorder generation or manual restocking.
enum InventoryPurchaseSource {
  reorder
  quick_restock
  manual
}

// Workflow state for a single purchase line inside a batch.
enum InventoryPurchaseLineStatus {
  draft
  ordered
  received
}

// High-level lifecycle state for a project.
enum ProjectStatus {
  planning
  active
  on_hold
  completed
  cancelled
}

// Labels the purpose of a project note for filtering and context.
enum NoteCategory {
  research
  reference
  decision
  measurement
  general
}

// Polymorphic target type for universal structured entries.
enum EntryEntityType {
  hobby
  hobby_series
  hobby_session
  hobby_project
  hobby_project_milestone
  hobby_collection_item
  project
  project_phase
  asset
  schedule
  maintenance_log
  inventory_item
  notebook
}

// High-level classification for a universal entry.
enum EntryType {
  note
  observation
  measurement
  lesson
  decision
  issue
  milestone
  reference
  comparison
}

// Behavioral flags that affect how entries are surfaced and filtered.
enum EntryFlag {
  important
  actionable
  resolved
  pinned
  tip
  warning
  archived
}

// Distinguishes plain-text entry bodies from rich (HTML) content.
enum BodyFormat {
  plain_text
  rich_text
}

// Lifecycle state of a household invitation token.
enum InvitationStatus {
  pending
  accepted
  expired
  revoked
}

// Describes how an asset participates in a project.
enum ProjectAssetRelationship {
  target   // Asset is the thing the project is acting on
  produces // Project creates, installs, or yields this asset
  consumes // Project uses the asset as an input or expendable
  supports // Asset is supporting equipment, tooling, or infrastructure
}

// Polymorphic target type for uploaded file attachments.
enum AttachmentEntityType {
  maintenance_log
  asset
  project
  project_note
  project_expense
  project_phase
  project_task
  inventory_item
}

// Distinguishes stock that gets consumed from durable gear.
enum InventoryItemType {
  consumable
  equipment
}

enum SpaceType {
  building
  room
  area
  shelf
  cabinet
  drawer
  tub
  bin
  other
}

enum SpaceItemAction {
  placed
  removed
  moved_in
  moved_out
  quantity_changed
}

enum SpaceScanMethod {
  qr_scan
  manual_lookup
  direct_navigation
}

// Lifecycle state for a hobby workspace.
enum HobbyStatus {
  active
  paused
  archived
}

// High-level activity classification used to tailor hobby UI surfaces.
enum HobbyActivityMode {
  session
  project
  practice
  collection
}

// Controls whether sessions use a simple status or a custom pipeline.
enum HobbySessionLifecycleMode {
  binary   // Sessions are simply active/completed without pipeline stages
  pipeline // Sessions move through hobby-defined workflow steps
}

// Lifecycle state for a tracked hobby series or lineage of sessions.
enum SeriesStatus {
  active
  completed
  archived
}

// Identifies whether a recipe came from the library, the user, or an import.
enum HobbyRecipeSourceType {
  preset   // Seeded from the built-in preset library
  user
  imported // Brought in from an external source or file
}

// Categorizes journal entries recorded against hobbies or sessions.
enum HobbyLogType {
  note
  tasting
  progress
  issue
}

enum HobbyProjectStatus {
  planned
  active
  paused
  completed
  abandoned
}

enum HobbyPracticeGoalType {
  metric_target
  session_count
  duration_total
  custom
}

enum HobbyPracticeGoalStatus {
  active
  achieved
  abandoned
  paused
}

enum HobbyPracticeRoutineFrequency {
  daily
  weekly
  biweekly
  monthly
}

enum HobbyCollectionItemStatus {
  active
  dormant
  retired
  lost
  deceased
}

enum MilestoneStatus {
  pending
  in_progress
  completed
  skipped
}

enum CommentEntityType {
  asset
  project
  hobby
  inventory_item
}

enum WebhookDeliveryStatus {
  pending
  delivered
  failed
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  CORE — USERS & HOUSEHOLDS                                      ║
// ╚══════════════════════════════════════════════════════════════════╝

// A person with an account. Participates in households and authors user-scoped records.
model User {
  id                      String                @id @default(cuid())
  clerkUserId             String                @unique
  email                   String?               @unique
  displayName             String?
  notificationPreferences Json                  @default("{}")
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  householdMemberships    HouseholdMember[]
  householdsCreated       Household[]           @relation("HouseholdCreator")
  createdAssets           Asset[]               @relation("AssetCreator")
  ownedAssets             Asset[]               @relation("AssetOwner")
  createdPresetProfiles   PresetProfile[]       @relation("PresetProfileCreator")
  maintenanceLogs         MaintenanceLog[]      @relation("MaintenanceLogUser")
  notifications           Notification[]
  assignedSchedules       MaintenanceSchedule[] @relation("ScheduleAssignee")
  assignedProjectTasks    ProjectTask[]         @relation("ProjectTaskAssignee")
  activityLogs            ActivityLog[]
  initiatedAssetTransfers AssetTransfer[]       @relation("AssetTransferInitiator")
  outgoingAssetTransfers  AssetTransfer[]       @relation("AssetTransferFromUser")
  incomingAssetTransfers  AssetTransfer[]       @relation("AssetTransferToUser")
  inventoryTransactions   InventoryTransaction[]
  inventoryPurchases      InventoryPurchase[]   @relation("InventoryPurchaseCreator")
  inventoryItemRevisions  InventoryItemRevision[]
  sentInvitations         HouseholdInvitation[] @relation("InvitationSender")
  acceptedInvitations     HouseholdInvitation[] @relation("InvitationAcceptor")
  authoredComments        Comment[]             @relation("CommentAuthor")
  timelineEntries         AssetTimelineEntry[]  @relation("TimelineEntryCreator")
  projectNotes            ProjectNote[]         @relation("ProjectNoteAuthor")
  attachments             Attachment[]          @relation("AttachmentUploader")
  createdShareLinks       ShareLink[]           @relation("ShareLinkCreator")
  createdHobbies          Hobby[]               @relation("HobbyCreator")
  createdHobbyProjects    HobbyProject[]        @relation("HobbyProjectCreator")
  createdHobbyPracticeGoals HobbyPracticeGoal[]   @relation("HobbyPracticeGoalCreator")
  createdHobbyPracticeRoutines HobbyPracticeRoutine[] @relation("HobbyPracticeRoutineCreator")
  createdHobbyCollectionItems HobbyCollectionItem[] @relation("HobbyCollectionItemCreator")
  createdEntries          Entry[]               @relation("EntryCreator")
  createdNoteFolders      NoteFolder[]          @relation("NoteFolderCreator")
  performedSpaceItemHistory SpaceItemHistory[]  @relation("SpaceItemHistoryPerformer")
  spaceScanLogs          SpaceScanLog[]
}

// A shared workspace that owns household-scoped assets, projects, inventory, and hobbies.
model Household {
  id               String                @id @default(cuid())
  name             String
  createdById      String
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  createdBy        User                  @relation("HouseholdCreator", fields: [createdById], references: [id], onDelete: Restrict)
  members          HouseholdMember[]
  assets           Asset[]
  presetProfiles   PresetProfile[]
  notifications    Notification[]
  serviceProviders ServiceProvider[]
  projects         Project[]
  projectTemplates ProjectTemplate[]
  inventoryItems   InventoryItem[]
  spaces           Space[]
  spaceGeneralItems SpaceGeneralItem[]
  spaceItemHistory SpaceItemHistory[]
  spaceScanLogs    SpaceScanLog[]
  inventoryPurchases InventoryPurchase[]
  inventoryItemRevisions InventoryItemRevision[]
  activityLogs     ActivityLog[]
  outgoingAssetTransfers AssetTransfer[]        @relation("AssetTransferFromHousehold")
  incomingAssetTransfers AssetTransfer[]        @relation("AssetTransferToHousehold")
  invitations      HouseholdInvitation[]
  attachments      Attachment[]
  shareLinks       ShareLink[]
  hobbies          Hobby[]
  hobbySeries      HobbySeries[]
  hobbyProjects    HobbyProject[]
  hobbyPracticeGoals HobbyPracticeGoal[]
  hobbyPracticeRoutines HobbyPracticeRoutine[]
  hobbyCollectionItems HobbyCollectionItem[]
  comments         Comment[]
  entries          Entry[]
  noteFolders      NoteFolder[]
  domainEvents     DomainEvent[]
  webhookEndpoints WebhookEndpoint[]

  @@index([createdById])
}

model Space {
  id             String                @id @default(cuid())
  householdId    String
  shortCode      String
  scanTag        String                @unique
  name           String
  type           SpaceType
  parentSpaceId  String?
  description    String?
  notes          String?
  sortOrder      Int                   @default(0)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  deletedAt      DateTime?
  household      Household             @relation(fields: [householdId], references: [id], onDelete: Cascade)
  parent         Space?                @relation("SpaceHierarchy", fields: [parentSpaceId], references: [id], onDelete: SetNull)
  children       Space[]               @relation("SpaceHierarchy")
  spaceItems     SpaceInventoryItem[]
  generalItems   SpaceGeneralItem[]
  itemHistory    SpaceItemHistory[]
  scanLogs       SpaceScanLog[]

  @@unique([householdId, shortCode])
  @@index([householdId, parentSpaceId])
  @@index([householdId, deletedAt])
}

// Join table linking a User to a Household with role-based membership.
model HouseholdMember {
  id          String        @id @default(cuid())
  householdId String
  userId      String
  role        HouseholdRole @default(member)
  joinedAt    DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
  @@index([userId])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  ASSETS                                                         ║
// ╚══════════════════════════════════════════════════════════════════╝

// A tracked real-world object or property. Belongs to a Household and anchors maintenance history.
model Asset {
  id                   String                @id @default(cuid())
  householdId          String
  createdById          String
  ownerId              String?
  parentAssetId        String?               // Optional parent for nested asset hierarchies
  assetTag             String?               @unique
  name                 String
  category             AssetCategory
  visibility           AssetVisibility       @default(shared)
  description          String?
  manufacturer         String?
  model                String?
  serialNumber         String?
  purchaseDate         DateTime?
  purchaseDetails      Json?
  warrantyDetails      Json?
  locationDetails      Json?
  insuranceDetails     Json?
  dispositionDetails   Json?
  conditionScore       Int?
  conditionHistory     Json                  @default("[]")
  assetTypeKey         String?
  assetTypeLabel       String?
  assetTypeDescription String?
  assetTypeSource      String                @default("manual")
  assetTypeVersion     Int                   @default(1)
  fieldDefinitions     Json                  @default("[]")
  customFields         Json                  @default("{}")
  isArchived           Boolean               @default(false)
  deletedAt            DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  household            Household             @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy            User                  @relation("AssetCreator", fields: [createdById], references: [id], onDelete: Restrict)
  owner                User?                 @relation("AssetOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  parentAsset          Asset?                @relation("AssetHierarchy", fields: [parentAssetId], references: [id], onDelete: SetNull)
  childAssets          Asset[]               @relation("AssetHierarchy")
  usageMetrics         UsageMetric[]
  schedules            MaintenanceSchedule[]
  logs                 MaintenanceLog[]
  timelineEntries      AssetTimelineEntry[]
  inventoryLinks       AssetInventoryItem[]
  notifications        Notification[]
  projectAssets        ProjectAsset[]
  comments             Comment[]
  transfers            AssetTransfer[]
  shareLinks           ShareLink[]
  hobbyLinks           HobbyAsset[]

  @@index([householdId, isArchived])
  @@index([createdById])
  @@index([ownerId])
  @@index([category])
  @@index([parentAssetId])
}

// Audit record for moving an asset between users or households.
model AssetTransfer {
  id              String            @id @default(cuid())
  assetId         String
  transferType    AssetTransferType
  fromHouseholdId String
  toHouseholdId   String?           // Target household for cross-household moves
  fromUserId      String
  toUserId        String
  initiatedById   String
  reason          String?
  notes           String?
  transferredAt   DateTime          @default(now())
  createdAt       DateTime          @default(now())
  asset           Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  fromHousehold   Household         @relation("AssetTransferFromHousehold", fields: [fromHouseholdId], references: [id], onDelete: Cascade)
  toHousehold     Household?        @relation("AssetTransferToHousehold", fields: [toHouseholdId], references: [id], onDelete: SetNull)
  fromUser        User              @relation("AssetTransferFromUser", fields: [fromUserId], references: [id], onDelete: Restrict)
  toUser          User              @relation("AssetTransferToUser", fields: [toUserId], references: [id], onDelete: Restrict)
  initiatedBy     User              @relation("AssetTransferInitiator", fields: [initiatedById], references: [id], onDelete: Restrict)

  @@index([assetId, transferredAt])
  @@index([fromHouseholdId, transferredAt])
  @@index([toHouseholdId, transferredAt])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  MAINTENANCE                                                    ║
// ╚══════════════════════════════════════════════════════════════════╝

// A numeric reading tracked on an Asset for usage-based maintenance logic.
model UsageMetric {
  id             String                @id @default(cuid())
  assetId        String
  name           String
  unit           String
  currentValue   Float                 @default(0)
  lastRecordedAt DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  asset          Asset                 @relation(fields: [assetId], references: [id], onDelete: Cascade)
  entries        UsageMetricEntry[]
  schedules      MaintenanceSchedule[]

  @@index([assetId])
}

// A single recorded reading for a UsageMetric, preserving its measurement history.
model UsageMetricEntry {
  id         String      @id @default(cuid())
  metricId   String
  value      Float
  recordedAt DateTime    @default(now())
  source     String      @default("manual")
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  metric     UsageMetric @relation(fields: [metricId], references: [id], onDelete: Cascade)

  @@index([metricId, recordedAt])
}

// A recurring or one-time maintenance rule on an Asset, optionally driven by a metric.
model MaintenanceSchedule {
  id                 String           @id @default(cuid())
  assetId            String
  metricId           String?          // Metric used when the trigger depends on usage
  name               String
  description        String?
  triggerType        TriggerType
  triggerConfig      Json
  notificationConfig Json             @default("{}")
  presetKey          String?
  estimatedCost      Float?
  estimatedMinutes   Int?
  isActive           Boolean          @default(true)
  isRegulatory       Boolean          @default(false)
  deletedAt          DateTime?
  lastCompletedAt    DateTime?
  nextDueAt          DateTime?
  nextDueMetricValue Float?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  asset              Asset            @relation(fields: [assetId], references: [id], onDelete: Cascade)
  metric             UsageMetric?     @relation(fields: [metricId], references: [id], onDelete: SetNull)
  assignedToId       String?
  logs               MaintenanceLog[]
  notifications      Notification[]
  inventoryItems     ScheduleInventoryItem[]
  linkedProjectTasks ProjectTask[]    @relation("ProjectTaskSchedule")
  assignedTo         User?            @relation("ScheduleAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([assetId, isActive])
  @@index([assetId, isActive, nextDueAt])
  @@index([assetId, deletedAt])
  @@index([metricId])
  @@index([nextDueAt])
  @@index([assignedToId])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  PRESET PROFILES                                                ║
// ╚══════════════════════════════════════════════════════════════════╝

// A household-scoped asset template containing reusable custom fields, metrics, and schedules.
model PresetProfile {
  id                   String        @id @default(cuid())
  householdId          String
  createdById          String
  key                  String
  name                 String
  category             AssetCategory
  description          String?
  tags                 String[]      @default([])
  customFieldTemplates Json          @default("[]")
  metricTemplates      Json          @default("[]")
  scheduleTemplates    Json          @default("[]")
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  household            Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy            User          @relation("PresetProfileCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@unique([householdId, key])
  @@index([householdId])
  @@index([createdById])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  SERVICE PROVIDERS                                              ║
// ╚══════════════════════════════════════════════════════════════════╝

// A household-scoped business or person referenced by maintenance logs and project expenses.
model ServiceProvider {
  id              String           @id @default(cuid())
  householdId     String
  name            String
  specialty       String?
  phone           String?
  email           String?
  website         String?
  address         String?
  rating          Int?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  household       Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  maintenanceLogs MaintenanceLog[]
  projectExpenses ProjectExpense[]

  @@index([householdId])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  MAINTENANCE RECORDS & NOTIFICATIONS                            ║
// ╚══════════════════════════════════════════════════════════════════╝

// A completed maintenance event on an Asset, optionally created from a schedule.
model MaintenanceLog {
  id                String               @id @default(cuid())
  assetId           String
  scheduleId        String?              // Source schedule when this log completes planned work
  completedById     String
  serviceProviderId String?
  title             String
  notes             String?
  completedAt       DateTime
  usageValue        Float?
  cost              Float?
  laborHours        Float?
  laborRate         Float?
  difficultyRating  Int?
  performedBy       String?
  metadata          Json                 @default("{}")
  deletedAt         DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  asset             Asset                @relation(fields: [assetId], references: [id], onDelete: Cascade)
  schedule          MaintenanceSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  completedBy       User                 @relation("MaintenanceLogUser", fields: [completedById], references: [id], onDelete: Restrict)
  serviceProvider   ServiceProvider?     @relation(fields: [serviceProviderId], references: [id], onDelete: SetNull)
  parts             MaintenanceLogPart[]

  @@index([assetId, completedAt])
  @@index([assetId, deletedAt])
  @@index([scheduleId])
  @@index([completedById])
  @@index([serviceProviderId])
}

// A part or material line item consumed during a MaintenanceLog entry.
model MaintenanceLogPart {
  id         String         @id @default(cuid())
  logId      String
  inventoryItemId String?   // Optional inventory source for stock deduction
  name       String
  partNumber String?
  quantity   Float          @default(1)
  unitCost   Float?
  supplier   String?
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  log        MaintenanceLog @relation(fields: [logId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)

  @@index([logId])
  @@index([inventoryItemId])
}

// A manual, user-authored event on an Asset timeline for history not covered by structured systems.
// TODO(2026-06): Remove after all asset history read/write paths rely exclusively on Entry records.
model AssetTimelineEntry {
  id          String    @id @default(cuid())
  assetId     String
  createdById String
  title       String
  description String?
  entryDate   DateTime
  category    String    @default("note")
  cost        Float?
  vendor      String?
  tags        Json      @default("[]")
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  asset       Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdBy   User      @relation("TimelineEntryCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([assetId, entryDate])
  @@index([createdById])
  @@index([category])
}

// A universal structured entry that can be attached to any major household entity.
model Entry {
  id             String          @id @default(cuid())
  householdId    String
  createdById    String
  title          String?         @db.VarChar(500)
  body           String          @db.VarChar(20000)
  bodyFormat     BodyFormat      @default(plain_text)
  entryDate      DateTime
  entityType     EntryEntityType
  entityId       String
  entryType      EntryType       @default(note)
  measurements   Json            @default("[]")
  tags           Json            @default("[]")
  attachmentUrl  String?
  attachmentName String?
  sourceType     String?
  sourceId       String?
  folderId       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  household      Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy      User            @relation("EntryCreator", fields: [createdById], references: [id], onDelete: Restrict)
  flags          EntryFlagEntry[]
  folder         NoteFolder?     @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([householdId, entityType, entityId])
  @@index([householdId, entryType])
  @@index([householdId, entryDate])
  @@index([householdId, createdById])
  @@index([folderId])
}

// Join table that assigns behavioral flags to entries.
model EntryFlagEntry {
  entryId    String
  flag       EntryFlag
  createdAt  DateTime @default(now())
  entry      Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@id([entryId, flag])
  @@index([flag])
}

// A hierarchical folder for organizing notes across the universal entry system.
model NoteFolder {
  id              String       @id @default(cuid())
  householdId     String
  parentFolderId  String?
  name            String       @db.VarChar(200)
  color           String?      @db.VarChar(30)
  icon            String?      @db.VarChar(30)
  sortOrder       Int          @default(0)
  createdById     String
  deletedAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  household       Household    @relation(fields: [householdId], references: [id], onDelete: Cascade)
  parent          NoteFolder?  @relation("NoteFolderTree", fields: [parentFolderId], references: [id], onDelete: SetNull)
  children        NoteFolder[] @relation("NoteFolderTree")
  createdBy       User         @relation("NoteFolderCreator", fields: [createdById], references: [id], onDelete: Restrict)
  entries         Entry[]

  @@index([householdId])
  @@index([parentFolderId])
}

// A generated alert for a user about asset or schedule activity within a household.
model Notification {
  id              String               @id @default(cuid())
  userId          String
  householdId     String?
  assetId         String?
  scheduleId      String?
  dedupeKey       String               @unique
  type            NotificationType
  channel         NotificationChannel
  status          NotificationStatus   @default(pending)
  title           String
  body            String
  scheduledFor    DateTime
  sentAt          DateTime?
  readAt          DateTime?
  escalationLevel Int                  @default(0)
  payload         Json                 @default("{}")
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  household       Household?           @relation(fields: [householdId], references: [id], onDelete: Cascade)
  asset           Asset?               @relation(fields: [assetId], references: [id], onDelete: Cascade)
  schedule        MaintenanceSchedule? @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([scheduledFor])
  @@index([householdId])
  @@index([assetId])
  @@index([scheduleId])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  PROJECTS - CORE                                                ║
// ╚══════════════════════════════════════════════════════════════════╝

// A household-scoped work effort that organizes phases, tasks, budgets, and linked resources.
model Project {
  id            String           @id @default(cuid())
  householdId   String
  name          String
  description   String?
  status        ProjectStatus    @default(planning)
  startDate     DateTime?
  targetEndDate DateTime?
  actualEndDate DateTime?
  budgetAmount    Float?
  notes           String?
  parentProjectId String?          // Parent for nested projects and rollup views
  depth           Int              @default(0)
  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  household       Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  parentProject   Project?         @relation("ProjectHierarchy", fields: [parentProjectId], references: [id], onDelete: Cascade)
  childProjects   Project[]        @relation("ProjectHierarchy")
  assets          ProjectAsset[]
  inventoryItems  ProjectInventoryItem[]
  phases          ProjectPhase[]
  budgetCategories ProjectBudgetCategory[]
  tasks           ProjectTask[]
  expenses        ProjectExpense[]
  noteEntries     ProjectNote[]
  templates       ProjectTemplate[]
  hobbyLinks       HobbyProjectLink[]
  comments         Comment[]

  @@index([householdId, status])
  @@index([householdId, deletedAt])
  @@index([parentProjectId])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  INVENTORY                                                      ║
// ╚══════════════════════════════════════════════════════════════════╝

// A household stock item or piece of equipment used across assets, projects, and hobbies.
model InventoryItem {
  id                 String                  @id @default(cuid())
  householdId        String
  scanTag            String?                 @unique
  itemType           InventoryItemType       @default(consumable)
  conditionStatus    String?
  name               String
  partNumber         String?
  description        String?
  category           String?
  manufacturer       String?
  quantityOnHand     Float                   @default(0)
  unit               String                  @default("each")
  reorderThreshold   Float?
  reorderQuantity    Float?
  preferredSupplier  String?
  supplierUrl        String?
  unitCost           Float?
  storageLocation    String?
  notes              String?
  deletedAt          DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  household          Household               @relation(fields: [householdId], references: [id], onDelete: Cascade)
  assetLinks         AssetInventoryItem[]
  spaceLinks         SpaceInventoryItem[]
  scheduleLinks      ScheduleInventoryItem[]
  projectLinks       ProjectInventoryItem[]
  projectPhaseSupplies ProjectPhaseSupply[]
  transactions       InventoryTransaction[]
  purchaseLines      InventoryPurchaseLine[]
  maintenanceLogParts MaintenanceLogPart[]
  hobbyLinks          HobbyInventoryItem[]
  hobbyProjectLinks   HobbyProjectInventoryItem[]
  hobbyRecipeIngredients HobbyRecipeIngredient[]
  hobbySessionIngredients HobbySessionIngredient[]
  hobbySessionStageSupplies HobbySessionStageSupply[]
  revisions          InventoryItemRevision[]
  comments           Comment[]
  spaceItemHistory   SpaceItemHistory[]

  @@index([householdId])
  @@index([householdId, deletedAt])
  @@index([householdId, category])
  @@index([householdId, partNumber])
  @@index([householdId, itemType])
  @@index([householdId, scanTag])
}

model SpaceInventoryItem {
  id              String        @id @default(cuid())
  spaceId         String
  inventoryItemId String
  quantity        Float?
  notes           String?
  placedAt        DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  space           Space         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@unique([spaceId, inventoryItemId])
  @@index([inventoryItemId])
}

model SpaceGeneralItem {
  id          String      @id @default(cuid())
  spaceId     String
  householdId String
  name        String
  description String?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?
  space       Space       @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  household   Household   @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([spaceId, deletedAt])
  @@index([householdId, deletedAt])
}

model SpaceItemHistory {
  id               String          @id @default(cuid())
  spaceId          String
  inventoryItemId  String?
  generalItemName  String?
  householdId      String
  action           SpaceItemAction
  quantity         Float?
  previousQuantity Float?
  performedBy      String?
  notes            String?
  createdAt        DateTime        @default(now())
  space            Space           @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  inventoryItem    InventoryItem?  @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  household        Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  performer        User?           @relation("SpaceItemHistoryPerformer", fields: [performedBy], references: [id], onDelete: SetNull)

  @@index([householdId, inventoryItemId])
  @@index([householdId, spaceId])
  @@index([spaceId, createdAt])
  @@index([inventoryItemId, createdAt])
  @@index([performedBy])
}

model SpaceScanLog {
  id          String          @id @default(cuid())
  householdId String
  spaceId     String
  userId      String
  scannedAt   DateTime        @default(now())
  method      SpaceScanMethod
  household   Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  space       Space           @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([householdId, scannedAt])
  @@index([spaceId, scannedAt])
  @@index([userId, scannedAt])
}

// Supplier-grouped purchase batch used for reorder carts and quick restocks.
model InventoryPurchase {
  id           String                  @id @default(cuid())
  householdId  String
  createdById  String
  supplierName String?
  supplierUrl  String?
  source       InventoryPurchaseSource @default(manual)
  status       InventoryPurchaseStatus @default(draft)
  notes        String?
  orderedAt    DateTime?
  receivedAt   DateTime?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  household    Household               @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy    User                    @relation("InventoryPurchaseCreator", fields: [createdById], references: [id], onDelete: Cascade)
  lines        InventoryPurchaseLine[]

  @@index([householdId, status])
  @@index([createdById])
}

// A single inventory item within a purchase batch.
model InventoryPurchaseLine {
  id               String                      @id @default(cuid())
  purchaseId       String
  inventoryItemId  String
  projectPhaseSupplyId String?
  status           InventoryPurchaseLineStatus @default(draft)
  plannedQuantity  Float
  orderedQuantity  Float?
  receivedQuantity Float?
  unitCost         Float?
  notes            String?
  orderedAt        DateTime?
  receivedAt       DateTime?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  purchase         InventoryPurchase           @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  inventoryItem    InventoryItem               @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  projectPhaseSupply ProjectPhaseSupply?       @relation(fields: [projectPhaseSupplyId], references: [id], onDelete: SetNull)

  @@index([purchaseId, status])
  @@index([inventoryItemId, status])
  @@index([projectPhaseSupplyId])
}

// Join table linking an Asset to the inventory items it uses or recommends.
model AssetInventoryItem {
  id                String        @id @default(cuid())
  assetId           String
  inventoryItemId   String
  notes             String?
  recommendedQuantity Float?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  asset             Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  inventoryItem     InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@unique([assetId, inventoryItemId])
  @@index([assetId])
  @@index([inventoryItemId])
}

// Join table linking a MaintenanceSchedule to inventory consumed on each service.
model ScheduleInventoryItem {
  id                 String              @id @default(cuid())
  scheduleId         String
  inventoryItemId    String
  quantityPerService Float               @default(1)
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  schedule           MaintenanceSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  inventoryItem      InventoryItem       @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@unique([scheduleId, inventoryItemId])
  @@index([inventoryItemId])
}

// Join table linking a Project to inventory with planned and allocated quantities.
model ProjectInventoryItem {
  id                String        @id @default(cuid())
  projectId         String
  inventoryItemId   String
  quantityNeeded    Float
  quantityAllocated Float         @default(0)
  budgetedUnitCost  Float?
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  project           Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inventoryItem     InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@unique([projectId, inventoryItemId])
  @@index([projectId])
  @@index([inventoryItemId])
}

// A stock movement entry for an InventoryItem, including source reference context.
model InventoryTransaction {
  id              String        @id @default(cuid())
  inventoryItemId String
  type            String
  quantity        Float
  quantityAfter   Float
  referenceType   String?
  referenceId     String?
  correctionOfTransactionId String?
  unitCost        Float?
  notes           String?
  userId          String
  createdAt       DateTime      @default(now())
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  correctionOfTransaction InventoryTransaction? @relation("InventoryTransactionCorrections", fields: [correctionOfTransactionId], references: [id], onDelete: SetNull)
  correctedByTransactions InventoryTransaction[] @relation("InventoryTransactionCorrections")
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([inventoryItemId, createdAt])
  @@index([correctionOfTransactionId])
  @@index([referenceType, referenceId])
  @@index([userId])
}

// Append-only metadata history for inventory item edits.
model InventoryItemRevision {
  id              String        @id @default(cuid())
  inventoryItemId String
  householdId     String
  userId          String
  action          String        @default("updated")
  changes         Json          @default("[]")
  createdAt       DateTime      @default(now())
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  household       Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([inventoryItemId, createdAt])
  @@index([householdId, createdAt])
  @@index([userId])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  PROJECTS - RELATIONSHIPS & EXECUTION                           ║
// ╚══════════════════════════════════════════════════════════════════╝

// Join table linking a Project to an Asset with the asset's role in that work.
model ProjectAsset {
  id           String                   @id @default(cuid())
  projectId    String
  assetId      String
  relationship ProjectAssetRelationship @default(target)
  role         String?
  notes        String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  project      Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asset        Asset                    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([projectId, assetId])
  @@index([projectId])
  @@index([assetId])
}

// An actionable work item within a Project, optionally tied to a phase or maintenance schedule.
model ProjectTask {
  id            String               @id @default(cuid())
  projectId     String
  phaseId       String?
  title         String
  description   String?
  status        String               @default("pending")
  taskType      String               @default("full")
  isCompleted   Boolean              @default(false)
  assignedToId  String?
  dueDate       DateTime?
  completedAt   DateTime?
  estimatedCost Float?
  actualCost    Float?
  estimatedHours Float?
  actualHours    Float?
  sortOrder     Int?
  scheduleId    String?              // Links task generation back to a maintenance schedule
  deletedAt     DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  project       Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase         ProjectPhase?        @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  assignedTo    User?                @relation("ProjectTaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  schedule      MaintenanceSchedule? @relation("ProjectTaskSchedule", fields: [scheduleId], references: [id], onDelete: SetNull)
  checklistItems ProjectTaskChecklistItem[]
  predecessorLinks ProjectTaskDependency[] @relation("ProjectTaskDependencySuccessor")
  successorLinks   ProjectTaskDependency[] @relation("ProjectTaskDependencyPredecessor")

  @@index([projectId, status])
  @@index([projectId, taskType])
  @@index([projectId, deletedAt])
  @@index([phaseId, sortOrder])
  @@index([phaseId, deletedAt])
  @@index([assignedToId])
}

// A finish-to-start dependency between two tasks in the same project.
model ProjectTaskDependency {
  predecessorTaskId String
  successorTaskId   String
  createdAt         DateTime    @default(now())
  predecessorTask   ProjectTask @relation("ProjectTaskDependencyPredecessor", fields: [predecessorTaskId], references: [id], onDelete: Cascade)
  successorTask     ProjectTask @relation("ProjectTaskDependencySuccessor", fields: [successorTaskId], references: [id], onDelete: Cascade)

  @@id([predecessorTaskId, successorTaskId])
  @@index([successorTaskId])
}

// A free-form note attached to a Project, optionally scoped to a single phase.
// TODO(2026-06): Remove after project note attachment parity is handled on Entry and legacy backfill is complete.
model ProjectNote {
  id             String        @id @default(cuid())
  projectId      String
  phaseId        String?
  title          String
  body           String        @default("")
  url            String?
  category       NoteCategory  @default(general)
  attachmentUrl  String?
  attachmentName String?
  isPinned       Boolean       @default(false)
  createdById    String
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase          ProjectPhase? @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  createdBy      User          @relation("ProjectNoteAuthor", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([projectId, category])
  @@index([projectId, isPinned])
  @@index([projectId, deletedAt])
  @@index([phaseId])
  @@index([phaseId, deletedAt])
  @@index([createdById])
}

// A cost entry recorded against a Project, phase, budget bucket, or service provider.
model ProjectExpense {
  id                String           @id @default(cuid())
  projectId         String
  phaseId           String?
  budgetCategoryId  String?
  description       String
  amount            Float
  category          String?
  date              DateTime?
  taskId            String?          // Optional related task ID; stored without a Prisma relation
  serviceProviderId String?
  notes             String?
  deletedAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  project           Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase             ProjectPhase?    @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  budgetCategory    ProjectBudgetCategory? @relation(fields: [budgetCategoryId], references: [id], onDelete: SetNull)
  serviceProvider   ServiceProvider? @relation(fields: [serviceProviderId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([projectId, deletedAt])
  @@index([phaseId])
  @@index([phaseId, deletedAt])
  @@index([budgetCategoryId])
}

// A stage within a Project that groups tasks, checklist items, supplies, expenses, and notes.
model ProjectPhase {
  id             String                      @id @default(cuid())
  projectId      String
  name           String
  description    String?
  status         String                      @default("pending")
  sortOrder      Int?
  startDate      DateTime?
  targetEndDate  DateTime?
  actualEndDate  DateTime?
  budgetAmount   Float?
  notes          String?
  deletedAt      DateTime?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  project        Project                     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks          ProjectTask[]
  checklistItems ProjectPhaseChecklistItem[]
  expenses       ProjectExpense[]
  supplies       ProjectPhaseSupply[]
  noteEntries    ProjectNote[]

  @@index([projectId, sortOrder])
  @@index([projectId, status])
  @@index([projectId, deletedAt])
}

// A phase-level checklist item used for milestone or acceptance tracking.
model ProjectPhaseChecklistItem {
  id           String       @id @default(cuid())
  phaseId      String
  title        String
  isCompleted  Boolean      @default(false)
  completedAt  DateTime?
  sortOrder    Int?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  phase        ProjectPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  @@index([phaseId, sortOrder])
}

// A checklist sub-item attached to a ProjectTask for fine-grained completion tracking.
model ProjectTaskChecklistItem {
  id           String      @id @default(cuid())
  taskId       String
  title        String
  isCompleted  Boolean     @default(false)
  completedAt  DateTime?
  sortOrder    Int?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  task         ProjectTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, sortOrder])
}

// A named budget bucket inside a Project that groups related expenses.
model ProjectBudgetCategory {
  id           String           @id @default(cuid())
  projectId    String
  name         String
  budgetAmount Float?
  sortOrder    Int?
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  expenses     ProjectExpense[]

  @@index([projectId, sortOrder])
}

// A supply requirement for a ProjectPhase, optionally backed by household inventory.
model ProjectPhaseSupply {
  id                String         @id @default(cuid())
  phaseId           String
  name              String
  category          String?
  description       String?
  quantityNeeded    Float
  quantityOnHand    Float          @default(0)
  unit              String         @default("each")
  estimatedUnitCost Float?
  actualUnitCost    Float?
  supplier          String?
  supplierUrl       String?
  isProcured        Boolean        @default(false)
  procuredAt        DateTime?
  isStaged          Boolean        @default(false)
  stagedAt          DateTime?
  inventoryItemId   String?        // Optional inventory item backing this supply line
  notes             String?
  sortOrder         Int?
  deletedAt         DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  phase             ProjectPhase   @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  inventoryItem     InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  purchaseLines     InventoryPurchaseLine[]

  @@index([phaseId, sortOrder])
  @@index([phaseId, category, sortOrder])
  @@index([phaseId, isProcured])
  @@index([phaseId, deletedAt])
  @@index([inventoryItemId])
}

// A reusable household-scoped project blueprint built from a live project snapshot.
model ProjectTemplate {
  id              String    @id @default(cuid())
  householdId     String
  sourceProjectId String?
  name            String
  description     String?
  notes           String?
  snapshot        Json
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  household       Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  sourceProject   Project?  @relation(fields: [sourceProjectId], references: [id], onDelete: SetNull)

  @@index([householdId, createdAt])
  @@index([sourceProjectId])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  SEARCH                                                         ║
// ╚══════════════════════════════════════════════════════════════════╝

// Search document row used to surface household content in the global search palette.
model SearchIndex {
  id               String                 @id
  householdId      String
  entityType       String                 // Indexed entity discriminator for search results
  entityId         String                 // ID of the indexed record
  parentEntityId   String?                // Parent asset or project used for grouped context
  parentEntityName String?
  title            String
  subtitle         String?
  body             String?
  searchVector     Unsupported("tsvector")
  entityUrl        String
  entityMeta       Json?
  updatedAt        DateTime               @updatedAt

  @@unique([householdId, entityType, entityId])
  @@index([householdId, entityType])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  ACTIVITY & AUDIT                                               ║
// ╚══════════════════════════════════════════════════════════════════╝

// Append-only audit trail of actions performed within a household.
model ActivityLog {
  id          String    @id @default(cuid())
  householdId String
  userId      String
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  createdAt   DateTime  @default(now())
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([householdId, createdAt])
  @@index([householdId, entityType])
  @@index([userId])
  @@index([entityType, entityId])
}

model DomainEvent {
  id          String   @id @default(cuid())
  householdId String
  eventType   String
  entityType  String
  entityId    String
  payload     Json     @default("{}")
  createdAt   DateTime @default(now())
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  deliveries  WebhookDelivery[]

  @@index([householdId, createdAt])
  @@index([householdId, eventType])
  @@index([entityType, entityId])
}

model WebhookEndpoint {
  id                   String   @id @default(cuid())
  householdId          String
  label                String
  url                  String
  secret               String?
  subscribedEventTypes String[] @default([])
  isActive             Boolean  @default(true)
  deletedAt            DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  household            Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  deliveries           WebhookDelivery[]

  @@index([householdId])
  @@index([householdId, deletedAt])
  @@index([householdId, isActive])
}

model WebhookDelivery {
  id                String                @id @default(cuid())
  webhookEndpointId String
  domainEventId     String
  status            WebhookDeliveryStatus @default(pending)
  responseStatus    Int?
  responseBody      String?
  attemptedAt       DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  webhookEndpoint   WebhookEndpoint       @relation(fields: [webhookEndpointId], references: [id], onDelete: Cascade)
  domainEvent       DomainEvent           @relation(fields: [domainEventId], references: [id], onDelete: Cascade)

  @@unique([webhookEndpointId, domainEventId])
  @@index([status, createdAt])
  @@index([webhookEndpointId])
  @@index([domainEventId])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  CORE — USERS & HOUSEHOLDS                                      ║
// ╚══════════════════════════════════════════════════════════════════╝

// An invitation token used to add a person to a Household by email.
// ╔══════════════════════════════════════════════════════════════════╗
// ║  INVITATIONS                                                    ║
// ╚══════════════════════════════════════════════════════════════════╝

model HouseholdInvitation {
  id               String           @id @default(cuid())
  householdId      String
  invitedByUserId  String
  email            String
  status           InvitationStatus @default(pending)
  token            String           @unique
  expiresAt        DateTime
  acceptedAt       DateTime?
  acceptedByUserId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  household        Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  invitedBy        User             @relation("InvitationSender", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  acceptedBy       User?            @relation("InvitationAcceptor", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([householdId])
  @@index([email])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  COMMENTS                                                       ║
// ╚══════════════════════════════════════════════════════════════════╝

// A threaded comment attached to an Asset, Project, Hobby, or InventoryItem.
model Comment {
  id              String    @id @default(cuid())
  householdId     String
  entityType      CommentEntityType
  entityId        String
  assetId         String?
  projectId       String?
  hobbyId         String?
  inventoryItemId String?
  authorId        String
  body            String
  parentCommentId String?
  editedAt        DateTime?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  household       Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  asset           Asset?    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  project         Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  hobby           Hobby?    @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  author          User      @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parentComment   Comment?  @relation("CommentThread", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies         Comment[] @relation("CommentThread")

  @@index([householdId, entityType, entityId, createdAt])
  @@index([assetId, createdAt])
  @@index([projectId, createdAt])
  @@index([hobbyId, createdAt])
  @@index([inventoryItemId, createdAt])
  @@index([authorId])
  @@index([parentCommentId])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  BARCODE                                                        ║
// ╚══════════════════════════════════════════════════════════════════╝

// Cached barcode lookup response used to avoid repeated external API calls.
model BarcodeLookup {
  id             String   @id @default(cuid())
  barcode        String   @unique
  barcodeFormat  String
  productName    String?
  brand          String?
  description    String?
  category       String?
  imageUrl       String?
  sourceProvider String
  rawResponse    Json     @default("{}")
  lookupCount    Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([barcode])
  @@index([createdAt])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  FILE ATTACHMENTS                                               ║
// ╚══════════════════════════════════════════════════════════════════╝

// A polymorphic uploaded file record linked to household content through entityType and entityId.
model Attachment {
  id               String               @id @default(cuid())
  householdId      String
  uploadedById     String
  entityType       AttachmentEntityType // Discriminator for the attachment target type
  entityId         String               // ID of the attached asset, log, project entity, or item
  storageKey       String               @unique
  originalFilename String
  mimeType         String
  fileSize         Int
  thumbnailKey     String?
  ocrResult        Json?
  caption          String?
  sortOrder        Int?
  status           String               @default("pending")
  deletedAt        DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  household        Household            @relation(fields: [householdId], references: [id], onDelete: Cascade)
  uploadedBy       User                 @relation("AttachmentUploader", fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([householdId])
  @@index([entityType, entityId])
  @@index([uploadedById])
  @@index([storageKey])
  @@index([status])
}

model ShareLink {
  id             String    @id @default(cuid())
  householdId     String
  assetId         String
  createdById     String
  token           String    @unique
  label           String?
  expiresAt       DateTime?
  isRevoked       Boolean   @default(false)
  viewCount       Int       @default(0)
  lastViewedAt    DateTime?
  dateRangeStart  DateTime?
  dateRangeEnd    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  household       Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  asset           Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdBy       User      @relation("ShareLinkCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([token])
  @@index([assetId])
  @@index([householdId])
  @@index([createdById])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  HOBBIES                                                        ║
// ╚══════════════════════════════════════════════════════════════════╝

// A household-scoped hobby workspace containing recipes, sessions, logs, metrics, and linked resources.
model Hobby {
  id               String                    @id @default(cuid())
  householdId      String
  name             String
  description      String?
  status           HobbyStatus               @default(active)
  activityMode     HobbyActivityMode         @default(session)
  hobbyType        String?
  lifecycleMode    HobbySessionLifecycleMode @default(binary)
  customFields     Json                      @default("{}")
  fieldDefinitions Json                      @default("[]")
  notes            String?
  createdById      String
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  household        Household                 @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy        User                      @relation("HobbyCreator", fields: [createdById], references: [id], onDelete: Restrict)
  recipes          HobbyRecipe[]
  series           HobbySeries[]
  sessions         HobbySession[]
  metricDefinitions HobbyMetricDefinition[]
  statusPipeline   HobbySessionStatusStep[]
  logs             HobbyLog[]
  assetLinks       HobbyAsset[]
  inventoryLinks   HobbyInventoryItem[]
  projectLinks     HobbyProjectLink[]
  projects         HobbyProject[]
  practiceGoals    HobbyPracticeGoal[]
  practiceRoutines HobbyPracticeRoutine[]
  collectionItems  HobbyCollectionItem[]
  inventoryCategories HobbyInventoryCategory[]
  comments         Comment[]

  @@index([householdId, status])
  @@index([householdId, activityMode])
  @@index([createdById])
}

// Join table linking a Hobby to an Asset used as tracked equipment or context.
model HobbyAsset {
  id          String   @id @default(cuid())
  hobbyId     String
  assetId     String
  role        String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  hobby       Hobby    @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([hobbyId, assetId])
  @@index([hobbyId])
  @@index([assetId])
}

// Join table linking a Hobby to household inventory items it uses or tracks.
model HobbyInventoryItem {
  id              String        @id @default(cuid())
  hobbyId         String
  inventoryItemId String
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  hobby           Hobby         @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@unique([hobbyId, inventoryItemId])
  @@index([hobbyId])
  @@index([inventoryItemId])
}

// Join table linking a Hobby to a related Project.
model HobbyProjectLink {
  id        String   @id @default(cuid())
  hobbyId   String
  projectId String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  hobby     Hobby    @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([hobbyId, projectId])
  @@index([hobbyId])
  @@index([projectId])
}

model HobbyProject {
  id            String             @id @default(cuid())
  hobbyId       String
  householdId   String
  createdById   String
  name          String             @db.VarChar(300)
  description   String?            @db.VarChar(5000)
  status        HobbyProjectStatus @default(planned)
  startDate     DateTime?
  targetEndDate DateTime?
  completedDate DateTime?
  coverImageUrl String?
  difficulty    String?
  notes         String?
  tags          Json               @default("[]")
  seriesId      String?
  batchNumber   Int?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  hobby         Hobby              @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
  household     Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy     User               @relation("HobbyProjectCreator", fields: [createdById], references: [id], onDelete: Restrict)
  series        HobbySeries?       @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  milestones    HobbyProjectMilestone[]
  workLogs      HobbyProjectWorkLog[]
  inventoryItems HobbyProjectInventoryItem[]

  @@index([hobbyId, status])
  @@index([hobbyId, updatedAt])
  @@index([householdId, status])
  @@index([seriesId, batchNumber])
  @@index([createdById])
}

model HobbyPracticeGoal {
  id                 String                  @id @default(cuid())
  hobbyId            String
  householdId        String
  createdById        String
  name               String                  @db.VarChar(300)
  description        String?                 @db.VarChar(2000)
  goalType           HobbyPracticeGoalType
  targetValue        Float
  currentValue       Float                   @default(0)
  unit               String
  metricDefinitionId String?
  startDate          DateTime?
  targetDate         DateTime?
  status             HobbyPracticeGoalStatus @default(active)
  tags               Json                    @default("[]")
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  hobby              Hobby                   @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
  household          Household               @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy          User                    @relation("HobbyPracticeGoalCreator", fields: [createdById], references: [id], onDelete: Restrict)
  metricDefinition   HobbyMetricDefinition?  @relation(fields: [metricDefinitionId], references: [id], onDelete: SetNull)

  @@index([hobbyId, status])
  @@index([householdId, status])
  @@index([metricDefinitionId])
  @@index([createdById])
}

model HobbyPracticeRoutine {
  id                      String                       @id @default(cuid())
  hobbyId                 String
  householdId             String
  createdById             String
  name                    String                       @db.VarChar(300)
  description             String?                      @db.VarChar(2000)
  targetDurationMinutes   Int?
  targetFrequency         HobbyPracticeRoutineFrequency
  targetSessionsPerPeriod Int                          @default(1)
  isActive                Boolean                      @default(true)
  currentStreak           Int                          @default(0)
  longestStreak           Int                          @default(0)
  notes                   String?
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt
  hobby                   Hobby                        @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
  household               Household                    @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy               User                         @relation("HobbyPracticeRoutineCreator", fields: [createdById], references: [id], onDelete: Restrict)
  sessions                HobbySession[]

  @@index([hobbyId, isActive])
  @@index([householdId, isActive])
  @@index([createdById])
}

model HobbyCollectionItem {
  id            String                    @id @default(cuid())
  hobbyId       String
  householdId   String
  createdById   String
  name          String                    @db.VarChar(300)
  description   String?                   @db.VarChar(2000)
  status        HobbyCollectionItemStatus @default(active)
  acquiredDate  DateTime?
  retiredDate   DateTime?
  coverImageUrl String?
  location      String?                   @db.VarChar(200)
  customFields  Json                      @default("{}")
  quantity      Int                       @default(1)
  tags          Json                      @default("[]")
  notes         String?
  parentItemId  String?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  hobby         Hobby                     @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
  household     Household                 @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy     User                      @relation("HobbyCollectionItemCreator", fields: [createdById], references: [id], onDelete: Restrict)
  parentItem    HobbyCollectionItem?      @relation("HobbyCollectionItemHierarchy", fields: [parentItemId], references: [id], onDelete: SetNull)
  childItems    HobbyCollectionItem[]     @relation("HobbyCollectionItemHierarchy")
  sessions      HobbySession[]

  @@index([hobbyId, status])
  @@index([hobbyId, location])
  @@index([householdId, status])
  @@index([parentItemId])
  @@index([createdById])
}

model HobbyProjectMilestone {
  id             String          @id @default(cuid())
  hobbyProjectId String
  name           String          @db.VarChar(300)
  description    String?         @db.VarChar(2000)
  status         MilestoneStatus @default(pending)
  sortOrder      Int
  targetDate     DateTime?
  completedDate  DateTime?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  hobbyProject   HobbyProject    @relation(fields: [hobbyProjectId], references: [id], onDelete: Cascade)
  workLogs       HobbyProjectWorkLog[]

  @@index([hobbyProjectId, sortOrder])
  @@index([hobbyProjectId, status])
}

model HobbyProjectWorkLog {
  id             String                @id @default(cuid())
  hobbyProjectId String
  milestoneId    String?
  date           DateTime
  durationMinutes Int?
  description    String                @db.VarChar(5000)
  notes          String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  hobbyProject   HobbyProject          @relation(fields: [hobbyProjectId], references: [id], onDelete: Cascade)
  milestone      HobbyProjectMilestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)

  @@index([hobbyProjectId, date])
  @@index([milestoneId])
}

model HobbyProjectInventoryItem {
  id              String        @id @default(cuid())
  hobbyProjectId  String
  inventoryItemId String
  quantityNeeded  Float
  quantityUsed    Float         @default(0)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  hobbyProject    HobbyProject  @relation(fields: [hobbyProjectId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@unique([hobbyProjectId, inventoryItemId])
  @@index([hobbyProjectId])
  @@index([inventoryItemId])
}

// An organizational inventory grouping defined within a Hobby.
model HobbyInventoryCategory {
  id           String   @id @default(cuid())
  hobbyId      String
  categoryName String
  sortOrder    Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  hobby        Hobby    @relation(fields: [hobbyId], references: [id], onDelete: Cascade)

  @@unique([hobbyId, categoryName])
  @@index([hobbyId])
}

// A named step in a Hobby's custom session workflow pipeline.
model HobbySessionStatusStep {
  id        String   @id @default(cuid())
  hobbyId   String
  label     String
  description String? @db.VarChar(2000)
  instructions String? @db.VarChar(5000)
  futureNotes String? @db.VarChar(5000)
  fieldDefinitions Json @default("[]")
  checklistTemplates Json @default("[]")
  supplyTemplates Json @default("[]")
  sortOrder Int
  color     String?
  isFinal   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  hobby     Hobby    @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
  sessionStages HobbySessionStage[] @relation("HobbyStageTemplateInstances")

  @@index([hobbyId, sortOrder])
}

// A reusable recipe or procedure inside a Hobby, with ingredients and ordered steps.
model HobbyRecipe {
  id                String                 @id @default(cuid())
  hobbyId           String
  name              String
  description       String?
  sourceType        HobbyRecipeSourceType  @default(user)
  styleCategory     String?
  customFields      Json                   @default("{}")
  estimatedDuration String?
  estimatedCost     Float?
  yield             String?
  notes             String?
  isArchived        Boolean                @default(false)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  hobby             Hobby                  @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
  ingredients       HobbyRecipeIngredient[]
  steps             HobbyRecipeStep[]
  sessions          HobbySession[]

  @@index([hobbyId])
  @@index([hobbyId, isArchived])
}

// A material line in a HobbyRecipe, optionally linked to household inventory.
model HobbyRecipeIngredient {
  id              String         @id @default(cuid())
  recipeId        String
  inventoryItemId String?        // Optional inventory item for stock and cost awareness
  name            String
  quantity        Float
  unit            String
  category        String?
  notes           String?
  sortOrder       Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  recipe          HobbyRecipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  sessionIngredients HobbySessionIngredient[]

  @@index([recipeId, sortOrder])
  @@index([inventoryItemId])
}

// An ordered procedural step within a HobbyRecipe.
model HobbyRecipeStep {
  id              String      @id @default(cuid())
  recipeId        String
  title           String
  description     String?
  sortOrder       Int         @default(0)
  durationMinutes Int?
  stepType        String      @default("generic")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  recipe          HobbyRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  sessionSteps    HobbySessionStep[]

  @@index([recipeId, sortOrder])
}

// A lineage of related sessions used to compare repeat batches or iterations.
model HobbySeries {
  id                 String        @id @default(cuid())
  hobbyId            String
  householdId        String
  name               String
  description        String?
  status             SeriesStatus  @default(active)
  batchCount         Int           @default(0)
  bestBatchSessionId String?
  tags               Json          @default("[]")
  notes              String?
  coverImageUrl      String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  hobby              Hobby         @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
  household          Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  sessions           HobbySession[] @relation("HobbySeriesSessions")
  hobbyProjects      HobbyProject[]
  bestBatchSession   HobbySession? @relation("HobbySeriesBestBatchSession", fields: [bestBatchSessionId], references: [id], onDelete: SetNull)

  @@index([hobbyId, status])
  @@index([householdId, status])
}

// A single execution of a Hobby, optionally derived from a recipe and workflow pipeline.
model HobbySession {
  id              String       @id @default(cuid())
  hobbyId         String
  recipeId        String?
  seriesId        String?
  routineId       String?
  collectionItemId String?
  batchNumber     Int?
  name            String
  status          String       @default("active")
  startDate       DateTime?
  completedDate   DateTime?
  durationMinutes Int?
  pipelineStepId  String?      // Current step in the hobby's custom session pipeline
  customFields    Json         @default("{}")
  totalCost       Float?
  rating          Int?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  hobby           Hobby        @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
  recipe          HobbyRecipe? @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  series          HobbySeries? @relation("HobbySeriesSessions", fields: [seriesId], references: [id], onDelete: SetNull)
  routine         HobbyPracticeRoutine? @relation(fields: [routineId], references: [id], onDelete: SetNull)
  collectionItem  HobbyCollectionItem? @relation(fields: [collectionItemId], references: [id], onDelete: SetNull)
  bestOfSeries    HobbySeries[] @relation("HobbySeriesBestBatchSession")
  ingredients     HobbySessionIngredient[]
  steps           HobbySessionStep[]
  stages          HobbySessionStage[]
  metricReadings  HobbyMetricReading[]
  logs            HobbyLog[]

  @@index([hobbyId, status])
  @@index([hobbyId, createdAt])
  @@index([recipeId])
  @@index([seriesId, batchNumber])
  @@index([routineId])
  @@index([collectionItemId])
}

// A concrete stage instance inside a HobbySession, cloned from the hobby workflow definition.
model HobbySessionStage {
  id               String                   @id @default(cuid())
  sessionId        String
  stageTemplateId  String?
  name             String
  description      String?                  @db.VarChar(2000)
  instructions     String?                  @db.VarChar(5000)
  futureNotes      String?                  @db.VarChar(5000)
  fieldDefinitions Json                     @default("[]")
  sortOrder        Int
  startedAt        DateTime?
  completedAt      DateTime?
  notes            String?
  customFieldValues Json                    @default("{}")
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  session          HobbySession             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  stageTemplate    HobbySessionStatusStep?  @relation("HobbyStageTemplateInstances", fields: [stageTemplateId], references: [id], onDelete: SetNull)
  checklistItems   HobbySessionStageChecklistItem[]
  supplies         HobbySessionStageSupply[]

  @@index([sessionId, sortOrder])
  @@index([stageTemplateId])
}

// A lightweight checklist/todo item attached to a session stage.
model HobbySessionStageChecklistItem {
  id             String            @id @default(cuid())
  sessionStageId String
  title          String
  sortOrder      Int               @default(0)
  isCompleted    Boolean           @default(false)
  completedAt    DateTime?
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  sessionStage   HobbySessionStage @relation(fields: [sessionStageId], references: [id], onDelete: Cascade)

  @@index([sessionStageId, sortOrder])
}

// A needed supply or inventory line for a specific session stage.
model HobbySessionStageSupply {
  id              String            @id @default(cuid())
  sessionStageId  String
  inventoryItemId String?
  name            String
  quantityNeeded  Float
  unit            String
  isRequired      Boolean           @default(true)
  notes           String?
  sortOrder       Int               @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  sessionStage    HobbySessionStage @relation(fields: [sessionStageId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem?    @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)

  @@index([sessionStageId, sortOrder])
  @@index([inventoryItemId])
}

// A material actually consumed during a HobbySession, optionally traced to recipe and inventory rows.
model HobbySessionIngredient {
  id                   String                 @id @default(cuid())
  sessionId            String
  recipeIngredientId   String?                // Source recipe ingredient when copied from a recipe
  inventoryItemId      String?                // Inventory item consumed by this session ingredient
  name                 String
  quantityUsed         Float
  unit                 String
  unitCost             Float?
  notes                String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  session              HobbySession           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  recipeIngredient     HobbyRecipeIngredient? @relation(fields: [recipeIngredientId], references: [id], onDelete: SetNull)
  inventoryItem        InventoryItem?         @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([inventoryItemId])
}

// A concrete step performed during a HobbySession, optionally derived from a recipe step.
model HobbySessionStep {
  id              String           @id @default(cuid())
  sessionId       String
  recipeStepId    String?          // Source recipe step when the session is recipe-based
  title           String
  description     String?
  sortOrder       Int              @default(0)
  isCompleted     Boolean          @default(false)
  completedAt     DateTime?
  durationMinutes Int?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  session         HobbySession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  recipeStep      HobbyRecipeStep? @relation(fields: [recipeStepId], references: [id], onDelete: SetNull)

  @@index([sessionId, sortOrder])
}

// A numeric metric definition tracked across sessions within a Hobby.
model HobbyMetricDefinition {
  id          String               @id @default(cuid())
  hobbyId     String
  name        String
  unit        String
  description String?
  metricType  String               @default("numeric")
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  hobby       Hobby                @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
  readings    HobbyMetricReading[]
  practiceGoals HobbyPracticeGoal[]

  @@unique([hobbyId, name])
  @@index([hobbyId])
}

// A recorded value for a Hobby metric, optionally tied to a specific session.
model HobbyMetricReading {
  id                 String                @id @default(cuid())
  metricDefinitionId String
  sessionId          String?
  value              Float
  readingDate        DateTime
  notes              String?
  createdAt          DateTime              @default(now())
  metricDefinition   HobbyMetricDefinition @relation(fields: [metricDefinitionId], references: [id], onDelete: Cascade)
  session            HobbySession?         @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([metricDefinitionId, readingDate])
  @@index([sessionId])
}

// A dated journal entry for a Hobby, optionally attached to a particular session.
// TODO(2026-06): Remove after hobby exports/session payloads stop depending on legacy HobbyLog rows.
model HobbyLog {
  id        String        @id @default(cuid())
  hobbyId   String
  sessionId String?
  title     String?
  content   String
  logDate   DateTime
  logType   HobbyLogType  @default(note)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  hobby     Hobby         @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
  session   HobbySession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([hobbyId, logDate])
  @@index([sessionId])
}
