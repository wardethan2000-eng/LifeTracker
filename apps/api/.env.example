DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lifekeeper?schema=public"
AUTH_MODE="better-auth"
ALLOW_DEV_AUTH_BYPASS="true"
DEV_AUTH_DEFAULT_USER_ID="clkeeperuser0000000000001"
# Generate a strong random secret for production: openssl rand -hex 32
BETTER_AUTH_SECRET=""
APP_BASE_URL="http://localhost:4000"
CORS_ALLOWED_ORIGINS="http://127.0.0.1:3000,http://localhost:3000,http://localhost:8081"
# Local development defaults. Production should usually start lower and raise only where justified.
API_BODY_LIMIT_BYTES="1048576"
API_MAX_PARAM_LENGTH="200"
GLOBAL_RATE_LIMIT_MAX="300"
GLOBAL_RATE_LIMIT_WINDOW_MS="60000"
# Production starting point:
# API_BODY_LIMIT_BYTES="262144"
# API_MAX_PARAM_LENGTH="120"
# GLOBAL_RATE_LIMIT_MAX="120"
# GLOBAL_RATE_LIMIT_WINDOW_MS="60000"
NOTIFICATION_DELIVERY_MODE="log"
# Delivery modes:
#   "log"  — log notification details to console only (default for local dev)
#   "noop" — discard silently (useful in CI / automated tests)
#   "live" — send real email/push via configured adapters (production)

# ── Feature flags ────────────────────────────────────────────────────
# Set to "false" to disable a feature. Omit or set to any other value to enable.
# FEATURE_SPACES=false       # spatial item mapping, QR code scans, space analytics
# FEATURE_WEBHOOKS=false     # outbound webhook delivery and domain-event dispatch

# ── Minimal dev mode (use with compose.dev-minimal.yaml) ─────────────
# Set these to run with Postgres only — no Redis or MinIO required.
ENABLE_QUEUES=false
STORAGE_ENABLED=false
RATE_LIMIT_STORE=memory

# ── SMTP (required when NOTIFICATION_DELIVERY_MODE="live") ───────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=notifications@example.com
# SMTP_PASS=yourpassword
# SMTP_FROM="LifeKeeper <notifications@example.com>"
PORT="4000"

# ── Object Storage (S3-compatible) ────────────────────────────────────
# Local development: MinIO at http://localhost:9000
# Production: Cloudflare R2 or AWS S3
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=lifekeeper-attachments
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_UPLOAD_EXPIRES_SECONDS=300
S3_PRESIGN_DOWNLOAD_EXPIRES_SECONDS=3600
