{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@aegis/types": ["../../packages/types/src/index.ts"],
      "@aegis/utils": ["../../packages/utils/src/index.ts"],
      "@aegis/presets": ["../../packages/presets/src/index.ts"]
    }
  },
  "include": [
    "app/**/*.tsx",
    "app/**/*.ts",
    "components/**/*.tsx",
    "components/**/*.ts",
    "hooks/**/*.ts",
    "lib/**/*.ts",
    "screens/**/*.tsx",
    "App.tsx",
    "app.config.ts"
  ]
}
