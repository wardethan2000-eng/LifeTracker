# Aegis Mobile — Environment Variables
# Copy this to .env.local and fill in values for your environment.
# In development, these env vars are read by Expo and injected as EXPO_PUBLIC_* globals.

# API base URL (local dev Fastify server)
EXPO_PUBLIC_AEGIS_API_BASE_URL=http://127.0.0.1:4000

# Dev user ID — bypasses Clerk auth when __DEV__ is true.
# Must match a seeded user in your local database.
EXPO_PUBLIC_AEGIS_DEV_USER_ID=

# Clerk publishable key — only required in production builds.
# Leave empty for local dev (Clerk is bypassed).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# EAS Project ID — set when you've created the EAS project.
EAS_PROJECT_ID=
