# URL of the Fastify API server. Used by the BetterAuth client and server-side
# API calls. NEXT_PUBLIC_ prefix makes it available in the browser too.
NEXT_PUBLIC_LIFEKEEPER_API_BASE_URL="http://localhost:4000"

# Set to "true" to skip the session-cookie auth guard in middleware.
# Pair with ALLOW_DEV_AUTH_BYPASS=true in the API .env.
NEXT_PUBLIC_DEV_AUTH_BYPASS="true"
