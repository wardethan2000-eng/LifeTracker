{
  "name": "lifekeeper",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "turbo run format",
    "db:generate": "pnpm --filter @lifekeeper/api prisma:generate",
    "db:migrate": "pnpm --filter @lifekeeper/api prisma:migrate",
    "db:seed": "pnpm --filter @lifekeeper/api prisma:seed"
  },
  "devDependencies": {
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  }
}
