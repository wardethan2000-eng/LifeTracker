{
  "name": "lifekeeper",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.3",
  "scripts": {
    "build": "turbo run build",
    "benchmark:web": "pnpm --filter @lifekeeper/web benchmark",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "turbo run format",
    "db:generate": "pnpm --filter @lifekeeper/api prisma:generate",
    "db:migrate": "pnpm --filter @lifekeeper/api prisma:migrate",
    "db:seed": "pnpm --filter @lifekeeper/api prisma:seed",
    "db:repair-project-depths": "pnpm --filter @lifekeeper/api projects:repair-depths"
  },
  "devDependencies": {
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  }
}
